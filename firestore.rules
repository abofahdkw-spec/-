rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, settings, createdAt
    //
    // Collection: classes
    // Fields: id, name, teacherUid, createdAt
    //
    // Collection: students
    // Fields: id, name, classId, teacherUid, createdAt
    //
    // Collection: sessions
    // Fields: id, title, date, classId, teacherUid, createdAt
    //
    // Collection: attendance
    // Fields: id, sessionId, studentId, status, participation, teacherUid, createdAt
    //
    // Collection: evidence
    // Fields: id, title, description, category, date, fileUrl, fileName, teacherUid, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isTeacher(data) {
      return isAuthenticated() && request.auth.uid == data.teacherUid;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidInteger(val, min, max) {
      return val is int && val >= min && val <= max;
    }

    function isValidAttendance(data) {
      return data.attendance in ['Present', 'Absent', 'Late'] &&
             isValidInteger(data.participation, 0, 5);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && 
        request.resource.data.keys().hasAll(['uid', 'email']) &&
        request.resource.data.uid == uid;
    }

    match /classes/{classId} {
      allow read: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid &&
        isValidString(request.resource.data.name, 1, 100);
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid &&
        request.resource.data.teacherUid == resource.data.teacherUid &&
        isValidString(request.resource.data.name, 1, 100);
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }

    match /students/{studentId} {
      allow read: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid &&
        isValidString(request.resource.data.name, 1, 100);
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid &&
        request.resource.data.teacherUid == resource.data.teacherUid &&
        isValidString(request.resource.data.name, 1, 100);
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid &&
        isValidString(request.resource.data.title, 1, 200);
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid &&
        request.resource.data.teacherUid == resource.data.teacherUid &&
        isValidString(request.resource.data.title, 1, 200);
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid &&
        isValidAttendance(request.resource.data);
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid &&
        request.resource.data.teacherUid == resource.data.teacherUid &&
        isValidAttendance(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }

    match /evidence/{evidenceId} {
      allow read: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid &&
        isValidString(request.resource.data.title, 1, 200);
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid &&
        request.resource.data.teacherUid == resource.data.teacherUid &&
        isValidString(request.resource.data.title, 1, 200);
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create, update: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }

    match /communications/{communicationId} {
      allow read: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid &&
        request.resource.data.teacherUid == resource.data.teacherUid;
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }
  }
}
